# =============================================================================
# Channel-Flix — environment template for self-hosted VPS deployment
# =============================================================================
# Copy this file to `.env` on your VPS (next to package.json) BEFORE running
# `npm run build`. The VITE_* values are baked into the client bundle at build
# time — if you change them you must rebuild.
#
#   cp .env.example .env
#   nano .env            # fill in real values
#   npm ci
#   npm run build
#   pm2 start ecosystem.config.cjs
# =============================================================================

# --- Supabase (client bundle — required at BUILD time) -----------------------
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT"

# --- Supabase (server runtime — required at START time) ----------------------
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_PROJECT_ID="YOUR-PROJECT"
# Service role key — server-only, NEVER commit, NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...service-role-key..."

# --- Third-party API keys (server runtime) -----------------------------------
# These can ALSO be stored in the admin panel (app_settings table). If you set
# ALLOW_DB_ONLY_SECRETS=1 below, preflight will accept them being absent here.
TMDB_API_KEY=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# --- Node server runtime -----------------------------------------------------
NODE_ENV="production"
PORT="3000"
HOST="127.0.0.1"

# Set to "1" to let preflight pass when TMDB_API_KEY / TELEGRAM_BOT_TOKEN are
# only configured via the admin panel and not present in this file.
ALLOW_DB_ONLY_SECRETS="1"
